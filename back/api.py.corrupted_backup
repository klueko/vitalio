defmerge_thresholds(raw_thresholds:Optional[Dict[str,Any]])->Dict[str,float]:
    """Return complete threshold dictionary with defaults."""
thresholds=dict(ALERT_DEFAULT_THRESHOLDS)
ifnotisinstance(raw_thresholds,dict):
        returnthresholds

forkeyinALERT_DEFAULT_THRESHOLDS.keys():
        value=raw_thresholds.get(key)
ifvalueisNone:
            continue
try:
